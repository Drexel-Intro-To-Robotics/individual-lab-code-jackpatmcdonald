<!-- Launch file for Lab1 turtlebot3 simulation -->
<launch>
  <arg name="model" default="waffle"/>
  <env name="TURTLEBOT3_MODEL" value="$(arg model)"/>

  <!-- Start gazebo with empty world -->
  <include file="$(find turtlebot3_gazebo)/launch/turtlebot3_empty_world.launch"/>

  <!-- Delay 5s while gazebo loads -->
  <node pkg="lab1"
        type="my_turtlebot.py"
        name="turtlebot3_controller"
        output="screen"
        launch-prefix="bash -c 'sleep 5; $0 $@'"/>
  <!-- Include rosbag for recording outputs -->
  <node pkg="rosbag"
        type="record"
        name="rosbag_record"
        args="/odom /cmd_vel /imu -o /workspaces/MEM571/catkin_ws/data/recording"/>
  <!-- Include rviz for nav_pose -->
  <node pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find turtlebot3_gazebo)/rviz/turtlebot3_gazebo.rviz"/>
</launch>